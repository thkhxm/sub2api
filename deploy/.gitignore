# =============================================================================
# Sub2API Deploy Directory - Git Ignore
# =============================================================================

# Data directories (generated at runtime when using docker-compose.local.yml)
data/
postgres_data/
redis_data/

# Environment configuration (contains sensitive information)
.env

# PunkcodeAI 生产环境变量（由 punkcode-prepare.sh 现场生成，含明文密钥，绝不入库）
.env.punkcode.prod
.env.punkcode.prod.bak.*

# Backup files
*.backup
*.bak

# Temporary files
*.tmp
*.log
