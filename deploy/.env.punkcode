# =============================================================================
# PunkcodeAI Dev 环境变量
# =============================================================================
# 用法：
#   cd deploy
#   docker compose -f docker-compose.dev.yml -f docker-compose.punkcode.yml \
#     --env-file .env.punkcode up --build
#
# 上述命令做的事：
#   - 用 docker-compose.dev.yml 从本地源码构建 sub2api 镜像
#   - docker-compose.punkcode.yml 叠加 PunkcodeAI 专用配置（seed setting 等）
#   - .env.punkcode 提供端口 / 密码 / 密钥等
#
# 端口约定（避开常见占用）：
#   sub2api backend : 38080  （桌面端访问 http://localhost:38080）
#   postgres        : 容器内 5432，宿主机不暴露
#   redis           : 容器内 6379，宿主机不暴露
# =============================================================================

# --- 端口 ---
# 宿主机访问端口（避开常见 8080）
BIND_HOST=127.0.0.1
SERVER_PORT=38080

# --- Server ---
SERVER_MODE=debug
RUN_MODE=standard
TZ=Asia/Shanghai

# 后端用作 LLM 网关 base URL 兜底（/cli/llm 接口返出给桌面端）
# dev 时桌面端把这个 URL 当作 OpenAI/Anthropic/Gemini 网关入口
SERVER_FRONTEND_URL=http://localhost:38080

# --- PostgreSQL ---
POSTGRES_USER=punkcode
POSTGRES_PASSWORD=punkcode_dev_only_change_in_prod
POSTGRES_DB=punkcode

# --- Redis ---
REDIS_DB=0
REDIS_PASSWORD=

# --- Admin 账户（首次启动自动创建）---
# 桌面端开发时用这个账号登录 sub2api 后台配置上游账号 / channel / model
ADMIN_EMAIL=admin@punkcode.local
ADMIN_PASSWORD=Punkcode@dev2026

# --- JWT / TOTP 密钥（dev 用固定值，prod 必须重新生成）---
# TOTP_ENCRYPTION_KEY 必须是 64 字符的 hex 字符串（32 字节）
# JWT_SECRET 任意字符串都可，但建议也用 hex 便于轮转
# 生成命令：openssl rand -hex 32
JWT_SECRET=a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f99
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
